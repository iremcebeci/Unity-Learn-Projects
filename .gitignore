# Multi-Unity-project repository root .gitignore
# Use this at the ROOT of the repo when the repo contains multiple Unity projects.

.utmp/

# Unity generated folders in any subfolder/project
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Logs
*.log

# Blender
*.blend1
*.blend1.meta

# Optional Asset Store Tools
# [Aa]ssets/AssetStoreTools*

# JetBrains Rider
[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# Visual Studio / IDE
.vs/
.gradle/
ExportedObj/
.consulo/

# Auto-generated solution/project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt
mono_crash.*

# Builds / exports
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics
crashlytics-build.properties

# TestRunner
InitTestScene*.unity*

# Addressables
ServerData
[Aa]ssets/StreamingAssets/aa*
[Aa]ssets/AddressableAssetsData/link.xml*
[Aa]ssets/Addressables_Temp*
[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated test scenes
[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*